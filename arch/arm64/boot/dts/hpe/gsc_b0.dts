					  "", "", "RESET_OUT", "NMI_OUT", "", "", "", "", "", "";
		};

		gpiomisc: gpio@2 {
			compatible = "hpe,gxp-gpio-misc";
			#gpio-cells = <2>;
			vuhc0_handle = <&vuhc0>;
			gpio-line-names = "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "";
		};

		leds: leds {
			compatible = "gpio-leds";

			power {
				color = <LED_COLOR_ID_GREEN>;
				function = LED_FUNCTION_POWER;
				gpios = <&xreg 38 0>;
				default-state = "off";
			};

			heartbeat {
				color = <LED_COLOR_ID_GREEN>;
				function = LED_FUNCTION_HEARTBEAT;
				gpios = <&xreg 39 0>;
				default-state = "off";
			};

			identify {
				color = <LED_COLOR_ID_BLUE>;
				function = LED_FUNCTION_INDICATOR;
				gpios = <&xreg 46 0>;
				default-state = "off";
			};

			health_red {
				color = <LED_COLOR_ID_RED>;
				function = LED_FUNCTION_HEALTH;
				gpios = <&xreg 55 0>;
				default-state = "off";
			};

			health_amber {
				color = <LED_COLOR_ID_AMBER>;
				function = LED_FUNCTION_HEALTH;
				gpios = <&xreg 54 0>;
				default-state = "off";
			};
		};

		mid: mid@d1e10000 {
			compatible = "simple-mfd", "syscon";
			reg = <0xd1e10000 0xFF>;
		};

