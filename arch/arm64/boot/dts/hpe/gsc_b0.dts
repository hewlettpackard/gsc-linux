			/*BYTE 0x78, BITS[960 - 967]*/"", "", "", "", "", "", "", "",
			/*BYTE 0x79, BITS[968 - 975]*/"", "", "", "", "", "", "", "",
			/*BYTE 0x7A, BITS[976 - 983]*/"", "", "", "", "", "", "", "",
			/*BYTE 0x7B, BITS[984 - 991]*/"", "", "", "", "", "", "", "";
		};

		xreg_keys: xreg_keys {
			compatible = "gpio-keys-polled";
			poll-interval = <100>;

			IdButton {
				label = "ID Button";
				linux,code = <200>;
				gpios = <&xreg 1425 1>;
			};
		};

		vuhc: vuhc {
			compatible = "gpio-keys-polled";
			poll-interval = <100>;

			PortOwner@0 {
				label = "Port Owner";
				linux,code = <200>;
				gpios = <&gpiomisc 0 1>;
			};

			PortOwner@1 {
				label = "Port Owner";
				linux,code = <201>;
				gpios = <&gpiomisc 1 1>;
			};

			PortOwner@2 {
				label = "Port Owner";
				linux,code = <202>;
				gpios = <&gpiomisc 2 1>;
			};

			PortOwner@3 {
				label = "Port Owner";
				linux,code = <203>;
				gpios = <&gpiomisc 3 1>;
			};

			PortOwner@4 {
				label = "Port Owner";
				linux,code = <204>;
				gpios = <&gpiomisc 4 1>;
			};

			PortOwner@5 {
				label = "Port Owner";
				linux,code = <205>;
				gpios = <&gpiomisc 5 1>;
			};
		};

		vuhc0: vuhc@80400000 {
			compatible = "syscon";
			reg = <0x80400000 0x80>;
		};

		/* For now using old gxp-udc driver */
		/*
		vhub: usb-hub@80400800 {
			compatible = "hpe,gxp-hub";
			reg = <0x80400800 0x200>, <0x80401000 0x8000>;
			reg-names = "gxphub", "udc";
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
		};
		*/

		udcg: udcg@80400800 {
			compatible = "syscon";
			reg = <0x80400800 0x200>;
		};

		udc0: udc@80401000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80401000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <0>;
			fepnum = <4>;
			udcg-handle = <&udcg>;
		};

		udc1: udc@80402000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80402000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <1>;
			fepnum = <2>;
			udcg-handle = <&udcg>;
		};

		udc2: udc@80403000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80403000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <2>;
			fepnum = <2>;
			udcg-handle = <&udcg>;
		};

		udc3: udc@80404000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80404000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <3>;
			fepnum = <2>;
			udcg-handle = <&udcg>;
		};

		udc4: udc@80405000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80405000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <4>;
			fepnum = <3>;
			udcg-handle = <&udcg>;
		};

		udc5: udc@80406000 {
			compatible = "hpe,gxp-udc";
			reg = <0x80406000 0x1000>;
			interrupts = <0 109 4>;
			interrupt-parent = <&gic>;
			vdevnum = <5>;
			fepnum = <3>;
			udcg-handle = <&udcg>;
		};

		coretemp: coretemp@c0000130 {
			compatible = "hpe,gxp-coretemp";
			formula = <1>;
			reg = <0xc0000130 0x8>;
		};

		peci: peci@80000400 {
			compatible = "hpe,gxp-peci";
			reg = <0x80000400 0x200>;
			interrupts = <0 118 4>;
			interrupt-parent = <&gic>;
		};

		/*
		 * legacy KCS IPMI Runtime Device Registers : 80fd_0400 - 80fd_04ff
		 */
		kcs_reg: kcs_reg@80fd0400 {
			compatible = "hpe,gxp-kcs-bmc";
			reg = <0x80fd0400 0x100>, <0x80fc0400 0x100>;
			reg-names = "base", "cfg";
			interrupts = <0 102 4>, <0 150 4>;
			interrupt-parent = <&gic>;
			kcs_chan = <1>;
			status = "okay";
		};

		/*
		 * FN7 Device Registers : 8070_0000 - 8070_0fff
		 *                        807f_0000 - 807f_0fff
		 */
		fn7reg: fn7reg@80700000 {
			compatible = "generic-uio";
			linux,uio-name = "vtpm";
			reg = <0x80700000 0x1000>, <0x807f0000 0x1000>;
			reg-names = "vtpm_reg", "vtpm_cfg";
			interrupts = <0 121 4>;
			interrupt-names = "vtpm";
			interrupt-parent = <&gic>;
			number-of-dynamic-regions = <1>;
			dynamic-regions-sizes = <0x41000>;
			dma-bits = <0x40>;
		};

	};

	/*
	 * PCIe Root Port
	 */
	pcie: pcie@94000000 {
		/* NOTE: disabled by default, set to 'okay' for designs that use PCIe RC */
		status = "disabled";
		/*
		 * For SanJac, must use 'linkcheck' driver to verify link up before PCIe
		 * config reads, to avoid a fatal exception during probe if no device present
		 */
		compatible = "pci-host-ecam-generic-linkcheck";
		device_type = "pci";
		#address-cells = <3>;
		#size-cells = <2>;
		reg = <0x90000000 0x1000000>;
		ranges = <0x02000000 0 0xB0000000 0xB0000000 0 0x10000000>, /* 256MB non-prefetchable memory */
			 <0x01000000 0 0x91000000 0x91000000 0 0x00010000>; /* 64KB I/O space */
		bus-range = <0x00 0x0F>; /* Defining ECAM space for 16 buses */
		#interrupt-cells = <1>;
		interrupt-map = <0xc000 0x0 0x0 0x1 &gic 0x0 92 0x4>,
				<0xc000 0x0 0x0 0x2 &gic 0x0 93 0x4>,
				<0xc000 0x0 0x0 0x3 &gic 0x0 94 0x4>,
				<0xc000 0x0 0x0 0x4 &gic 0x0 95 0x4>;
		interrupt-map-mask = <0xc000 0x0 0x0 7>;
	};
};
