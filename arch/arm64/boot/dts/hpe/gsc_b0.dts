		gpiomisc: gpio@2 {
			compatible = "hpe,gxp-gpio-misc";
			#gpio-cells = <2>;
			vuhc0_handle = <&vuhc0>;
			gpio-line-names = "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "",
					  "", "", "", "", "", "", "", "", "", "";
		};

		leds: leds {
			compatible = "gpio-leds";

			power {
				gpios = <&xreg 38 0>;
				default-state = "off";
			};

			heartbeat {
				gpios = <&xreg 39 0>;
				default-state = "off";
			};

			identify {
				gpios = <&xreg 46 0>;
				default-state = "off";
			};

			health_red {
				gpios = <&xreg 53 0>;
				default-state = "off";
			};

			health_amber {
				gpios = <&xreg 52 0>;
				default-state = "off";
			};
		};

		mid: mid@d1e10000 {
			compatible = "simple-mfd", "syscon";
			reg = <0xd1e10000 0xFF>;
		};

