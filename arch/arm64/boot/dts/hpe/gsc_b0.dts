/*
 * IMPORTANT: If you add any macb interfaces here or modify any existing macb
 * device tree elements, you must make changes in U-Boot
 * (see U-Boot file boards/hpe/gsc/gsc_loader.c)
 */
		macb0: ethernet@c0004000 {
			compatible = "hpe,gsc-gem";
			reg = <0xc0004000 0x1000>;
			interrupts = <0 74 4>, <0 75 4>, <0 76 4>;
			interrupt-parent = <&gic>;
			phy-handle = <&ethernet_phy>;
			clock-names = "pclk", "hclk", "tx_clk";
			clocks = <&clk400>, <&clk400>, <&clk125>;
			phy-mode = "sgmii";
			#address-cells = <1>;
			#size-cells = <0>;
			ethernet_phy: ethernet-phy@0{
				reg = <0x0>;
			};
		};

		macb2: ethernet@c0006000 {
			compatible = "hpe,gsc-rmii";
			reg = <0xc0006000 0x1000>;
			interrupts = <0 80 4>, <0 81 4>, <0 82 4>;
			interrupt-parent = <&gic>;
			clock-names = "pclk", "hclk";
			clocks = <&clk400>, <&clk400>;
			phy-mode = "rmii";
			use-ncsi;
			ncsi,vlan-mode = <NCSI_VLAN_MODE_ANY>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		display_port: display_port@c0020000 {
			compatible = "display_port_platform_device";
			interrupts = <0 14 4>;
			interrupt-parent = <&gic>;
		};

		usbdrd_dwc3: usb@c4000000 {
			compatible = "snps,dwc3";
			reg = <0xc4000000 0x100000>;
			interrupts = <0 6 4>;
			interrupt-parent = <&gic>;
			clock-names = "ref", "bus_early", "suspend";
			clocks = <&clk20>, <&clk400>, <&clk391K>;
			maximum-speed = "super-speed";
		};

		thumbnail: thumbnail@c0000500 {
			compatible = "hpe,gxp-video-thumbnail";
			reg = <0xc0000500 0x20>;
			bits-per-pixel = <32>;
			width = <800>;
			height = <600>;
		};

