// SPDX-License-Identifier: GPL-2.0-only
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/net/ncsi.h>
/dts-v1/;

/ {
	#address-cells = <1>;
	#size-cells = <1>;
	compatible = "hpe,gsc";
	model = "Hewlett Packard Enterprise GSC BMC";

	chosen {
		bootargs = "earlycon=ns16550a,0xc00000f0 console=ttyS0,115200
			    uio_dmem_genirq.of_id=generic-uio net.ifnames=0 ";
	};

	aliases {
		ethernet0 = &macb0;
		ethernet1 = &macb2;
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0>;
			enable-method = "spin-table";
			cpu-release-addr = <0 0xa0008048>;
			next-level-cache = <&L2>;
			L2: l2-cache {
				compatible = "cache,arm,arch-cache";
			};
		};
		cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <1>;
			enable-method = "spin-table";
			cpu-release-addr = <0 0xa0008048>;
			next-level-cache = <&L2>;
		};
	};

	clocks {
		osc: osc {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-output-names = "osc";
			clock-frequency = <33333333>;
		};

		iopclk: iopclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clocks = <&osc>;
			clock-out-put-names = "iopclk";
			clock-frequency = <400000000>;
		};

		memclk: memclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clocks = <&osc>;
			clock-out-put-names = "memclk";
			clock-frequency = <800000000>;
		};

		clk125: clk125 {
			#clock-cells = <0>;
			compatible = "fixed-clock";
			clock-frequency = <125000000>;
		};

		clk20: clk20 {
			#clock-cells = <0>;
			compatible = "fixed-clock";
			clock-frequency = <20000000>;
		};

		clk400: clk400 {
			#clock-cells = <0>;
			compatible = "fixed-clock";
			clock-frequency = <400000000>;
		};

		clk391K: clk391K {
			#clock-cells = <0>;
			compatible = "fixed-clock";
			clock-frequency = <391000>;
		};

		emmcclk:emmcclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <200000000>;
			clock-output-names = "emmcclk";
		};
	};

	memory@00000000 {
		device_type = "memory";
		reg = <0x00000000 0x40000000>;
	};

	/* Last 64KB in this reserved region - buffer@10000000, is used for AVRAM */
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		reserved: buffer@10000000 {
			no-map;
			reg = <0x10000000 0x6010000>;
		};
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <1 13 0xf08>,
				<1 14 0xf08>,
				<1 11 0xf08>,
				<1 10 0xf08>;
		clock-frequency = <50000000>;
		interrupt-parent = <&gic>;
        };

	ahb@80000000 {
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		gic: gic@ce000000 {
			compatible = "arm,gic-v3";
			#interrupt-cells = <3>;
			ranges;
			interrupt-controller;
			redistributor-stride = <0x0 0x20000>;
			#redistributor-regions = <1>;
			reg = <0xce000000 0x10000>,
			      <0xce060000 0x40000>,
			      <0xce200000 0x40000>;
		};

		watchdog: watchdog@c0000090 {
			compatible = "hpe,gxp-wdt";
			reg = <0xc0000090 0x02>, <0xc0000096 0x01>;
		};

		kw_reg_wr {
			compatible = "hpe,gxp-kw-reg";
			vromoff_reg_val = <0x10000000 0x2>; //010:64MB(size)
			avrcfg_reg_val  = <0x14000000 0x5>; //0101:64KB(size)
		};

		uartc: serial@c00000f0 {
			compatible = "ns16550a";
			reg = <0xc00000f0 0x8>;
			interrupts = <0 19 4>;
			interrupt-parent = <&gic>;
			clock-frequency = <1846153>;
			reg-shift = <0>;
		};

		uarta: serial@c00000e0 {
			compatible = "ns16550a";
			reg = <0xc00000e0 0x8>;
			interrupts = <0 17 4>;
			interrupt-parent = <&gic>;
			clock-frequency = <1846153>;
			reg-shift = <0>;
		};

		uartb: serial@c00000e8 {
			compatible = "ns16550a";
			reg = <0xc00000e8 0x8>;
			interrupts = <0 18 4>;
			interrupt-parent = <&gic>;
			clock-frequency = <1846153>;
			reg-shift = <0>;
		};

		uarte: serial@c00003e0 {
			compatible = "ns16550a";
			reg = <0xc00003e0 0x8>;
			interrupts = <0 12 4>;
			interrupt-parent = <&gic>;
			clock-frequency = <1846153>;
			reg-shift = <0>;
		};

		vuart_a: vuart_a@80fd0200 {
			compatible = "hpe,gxp-vuart";
			reg = <0x80fd0200 0x100>, <0x80fc0230 0x100>;
			interrupts = <0 98 4>;
			interrupt-parent = <&gic>;
			clock-frequency = <1846153>;
			reg-shift = <0>;
			status = "okay";
			serial-line = <3>;
		};

		rtc: rtc@c0000600 {
			compatible = "hpe,gsc-rtc";
			reg = <0xc0000600 0x100>;
			interrupts = <0 9 4>;
			interrupt-parent = <&gic>;
		};

		spifi0: spifi@cef00000 {
			compatible = "hpe,gsc-spifi";
			reg = <0xcef00000 0x80>, <0xcef08000 0x100>, <0xf8000000 0x8000000>;
			interrupts = <0 20 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;

			flash@0 {
				compatible = "jedec,spi-nor";
				reg = <0>;
				spi-tx-bus-width = <2>;
				spi-rx-bus-width = <2>;
				partitions {
					compatible = "fixed-partitions";
					#address-cells = <1>;
					#size-cells = <1>;

					bmc@0 {
						label = "bmc";
						reg = <0x0 0x4000000>;
					};
					u-boot@120000 {
						label = "u-boot";
						reg = <0x120000 0x60000>;
					};
					u-boot-env@180000 {
						label = "u-boot-env";
						reg = <0x180000 0x20000>;
					};
					kernel@1a0000 {
						label = "kernel";
						reg = <0x1a0000 0xa00000>;
					};
					rofs@ba0000 {
						label = "rofs";
						reg = <0xba0000 0x3000000>;
					};
					rwfs@3C30000 {
						label = "rwfs";
						reg = <0x3C30000 0x250000>;
					};
					u-boot-signature@3f70000 {
						label = "u-boot-signature";
						reg = <0x3f70000 0x10000>;
					};
				};
			};

			flash@1 {
				compatible = "jedec,spi-nor";
				reg = <1>;
				spi-tx-bus-width = <2>;
				spi-rx-bus-width = <2>;
				partitions {
					compatible = "fixed-partitions";
					#address-cells = <1>;
					#size-cells = <1>;
					host-prime@0 {
						label = "host-prime";
						reg = <0x0 0x04000000>;
					};
				};
			};
		};

		vrom@10000000 {
			compatible = "mtd-ram";
			bank-width = <4>;
			reg = <0x10000000 0x4000000>;
			#address-cells = <1>;
			#size-cells = <1>;
			partition@0 {
				label = "vrom-prime";
				reg = <0x0 0x4000000>;
			};
		};

		i2c0: i2c@c0002000 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002000 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 32 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c1: i2c@c0002100 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002100 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 33 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c2: i2c@c0002200 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002200 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 34 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
			/* Proto EEPROM */
			24c02@55 {
				compatible = "atmel,24c32";
				pagesize = <8>;
				reg = <0x55>;
			};
			/*
			 * Production EEPROM
			 * 24c02@54 {
			 *	compatible = "atmel,24c32";
			 *	pagesize = <8>;
			 *	reg = <0x54>;
			 * };
			 *
			 * DC-SCM EEPROM
			 * 24c02@50 {
			 *	compatible = "atmel,24c128";
			 *	pagesize = <8>;
			 *	reg = <0x50>;
			 * };
			 */

		};

		i2c3: i2c@c0002300 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002300 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 35 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c4: i2c@c0002400 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002400 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 36 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c5: i2c@c0002500 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002500 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 37 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c6: i2c@c0002600 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002600 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 38 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c7: i2c@c0002700 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002700 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 39 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c8: i2c@c0002800 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002800 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 40 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2c9: i2c@c0002900 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0002900 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 41 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i3c19: i3c@c0003300 {
			compatible = "hpe,i3c-master";
			reg = <0xc0003300 0xff>;
			i2c-scl-hz = <100000>;
			interrupts = <0 51 4>;
			interrupt-parent = <&gic>;
			#address-cells = <3>;
			#size-cells = <0>;
			hub@0,0 {
				cp0-ldo-en = "disabled";
				cp1-ldo-en = "disabled";
				cp0-ldo-volt = "1.0V";
				cp1-ldo-volt = "1.0V";
				tp0145-ldo-en = "disabled";
				tp2367-ldo-en = "disabled";
				tp0145-ldo-volt = "1.0V";
				tp2367-ldo-volt = "1.0V";
				tp0145-pullup = "500R";
				tp2367-pullup = "500R";

				target-port@0 {
					mode = "i3c";
					pullup = "disabled";
				};
				target-port@1 {
					mode = "i3c";
					pullup = "enabled";
				};
				target-port@2 {
					mode = "i3c";
					pullup = "disabled";
				};
				target-port@3 {
					mode = "i3c";
					pullup = "enabled";
				};
			};
		};

		/*
		 * Aero DDC Engine
		 */
		i2c20: i2c@c0003400 {
			compatible = "hpe,gxp-i2c";
			reg = <0xc0003400 0x70>;
			bus-frequency = <100000>;
			interrupts = <0 63 4>;
			interrupt-parent = <&gic>;
			#address-cells = <1>;
			#size-cells = <0>;
		};

		i2cmux@0 {
			compatible = "i2c-mux-gpio";
			i2c-parent = <&i2c0>;
			status = "okay";
			mux-gpios = <&xreg 1056 GPIO_ACTIVE_HIGH
				     &xreg 1057 GPIO_ACTIVE_HIGH
				     &xreg 1058 GPIO_ACTIVE_HIGH
				     &xreg 1059 GPIO_ACTIVE_HIGH>;
			idle-state = <0>;
			#address-cells = <1>;
			#size-cells = <0>;
			i2cseg11: i2c0@1 {
				reg = <1>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg12: i2c0@2 {
				reg = <2>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg13: i2c0@3 {
				reg = <3>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg14: i2c0@4 {
				reg = <4>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg15: i2c0@5 {
				reg = <5>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg16: i2c0@6 {
				reg = <6>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg17: i2c0@7 {
				reg = <7>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg18: i2c0@8 {
				reg = <8>;
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		i2cmux@3 {
			compatible = "i2c-mux-gpio";
			i2c-parent = <&i2c3>;
			status = "okay";
			mux-gpios = <&xreg 1080 GPIO_ACTIVE_HIGH
				     &xreg 1081 GPIO_ACTIVE_HIGH
				     &xreg 1082 GPIO_ACTIVE_HIGH
				     &xreg 1083 GPIO_ACTIVE_HIGH>;
			idle-state = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			i2cseg19: i2c3@1 {
				reg = <1>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg20: i2c3@2 {
				reg = <2>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg21: i2c3@3 {
				reg = <3>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg22: i2c3@4 {
				reg = <4>;
				#address-cells = <1>;
				#size-cells = <0>;
			};
			i2cseg23: i2c3@5 {
				reg = <5>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg24: i2c3@6 {
				reg = <6>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg25: i2c3@7 {
				reg = <7>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg26: i2c3@8 {
				reg = <8>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg27: i2c3@9 {
				reg = <9>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg28: i2c3@10 {
				reg = <10>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg29: i2c3@11 {
				reg = <11>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg30: i2c3@12 {
				reg = <12>;
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		i2cmux@4 {
			compatible = "i2c-mux-gpio";
			i2c-parent = <&i2c4>;
			status = "okay";
			mux-gpios = <&xreg 1088 GPIO_ACTIVE_HIGH
				     &xreg 1089 GPIO_ACTIVE_HIGH
				     &xreg 1090 GPIO_ACTIVE_HIGH
				     &xreg 1091 GPIO_ACTIVE_HIGH
				     &xreg 1092 GPIO_ACTIVE_HIGH>;
			idle-state = <0>;
			#address-cells = <1>;
			#size-cells = <0>;
			i2cseg31: i2c4@1 {
				reg = <1>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg32: i2c4@2 {
				reg = <2>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg33: i2c4@3 {
				reg = <3>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg34: i2c4@4 {
				reg = <4>;
				#address-cells = <1>;
				#size-cells = <0>;
			};
			i2cseg35: i2c4@5 {
				reg = <5>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg36: i2c4@6 {
				reg = <6>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg37: i2c4@7 {
				reg = <7>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg38: i2c4@8 {
				reg = <8>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg39: i2c4@9 {
				reg = <9>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg40: i2c4@10 {
				reg = <10>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg41: i2c4@11 {
				reg = <11>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg42: i2c4@12 {
				reg = <12>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg43: i2c4@13 {
				reg = <13>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg44: i2c4@14 {
				reg = <14>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg45: i2c4@15 {
				reg = <15>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg46: i2c4@16 {
				reg = <16>;
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		/*
		 * IMPORTANT: dtbo files may overlay this so the name
		 * of each segment below should not be changed.
		 * For example 'i2cmux@5/i2c5@1'
		 */
		i2cmux@5 {
			compatible = "i2c-mux-gpio";
			i2c-parent = <&i2c5>;
			status = "okay";
			mux-gpios = <&xreg 1096 GPIO_ACTIVE_HIGH
				    &xreg 1097 GPIO_ACTIVE_HIGH
				    &xreg 1098 GPIO_ACTIVE_HIGH>;
			idle-state = <0>;
			#address-cells = <1>;
			#size-cells = <0>;
			i2cseg47: i2c5@1 {
				reg = <1>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg48: i2c5@2 {
				reg = <2>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg49: i2c5@3 {
				reg =<3>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg50: i2c5@4 {
				reg =<4>;
				#address-cells = <1>;
				#size-cells = <0>;
			};


		};

		i2cmux@6 {
			compatible = "i2c-mux-gpio";
			i2c-parent = <&i2c6>;
			status = "okay";
			mux-gpios = <&xreg 1104 GPIO_ACTIVE_HIGH
				     &xreg 1105 GPIO_ACTIVE_HIGH
				     &xreg 1106 GPIO_ACTIVE_HIGH
				     &xreg 1107 GPIO_ACTIVE_HIGH
				     &xreg 1108 GPIO_ACTIVE_HIGH>;
			idle-state = <0>;
			#address-cells = <1>;
			#size-cells = <0>;
			i2cseg51: i2c6@1 {
				reg = <1>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg52: i2c6@2 {
				reg = <2>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg53: i2c6@3 {
				reg = <3>;
				#address-cells = <1>;
				#size-cells = <0>;
			};

			i2cseg54: i2c6@4 {
				reg = <4>;
				#address-cells = <1>;
